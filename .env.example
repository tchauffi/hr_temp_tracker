# Arduino serial device on the HOST machine.
# Run `ls /dev/cu.usb*` (macOS) or `ls /dev/ttyUSB* /dev/ttyACM*` (Linux)
# after plugging in the Arduino to find the correct device name.
#
# Common values:
#   Linux:  /dev/ttyUSB0   or  /dev/ttyACM0
#   macOS:  /dev/cu.usbmodem14101
#
# start.sh auto-detects the first USB modem device; set this only to override.
SERIAL_DEV=/dev/cu.usbmodem11301

# TCP port used by socat to bridge the serial port to Docker containers.
# The api container connects to socket://host.docker.internal:PROXY_PORT.
# Change this only if port 8899 is already in use on your machine.
PROXY_PORT=8899

# Baud rate must match the Arduino sketch (Serial.begin value).
SERIAL_BAUD=9600
